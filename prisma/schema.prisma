generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model RoomType {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  description    String?
  capacityMin    Int
  capacityMax    Int
  beds           String
  pricePerNight  Int
  pricePerPerson Boolean   @default(false)
  inventory      Int       @default(1)
  imageUrl       String?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  bookings       Booking[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique
  status          BookingStatus @default(PENDING)
  roomTypeId      String
  roomType        RoomType      @relation(fields: [roomTypeId], references: [id])
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  guestName       String
  guestEmail      String
  guestPhone      String
  specialRequests String?
  pets            Int           @default(0)
  dayTourGuests   Int           @default(0)
  subtotal        Int
  petFee          Int           @default(0)
  dayTourFee      Int           @default(0)
  totalAmount     Int
  nights          Int
  depositAmount   Int           @default(0)
  paymentReference String?
  paymentProofUrl  String?
  invoiceUrl       String?
  partnerSource    String?
  partnerBookingReference String?
  groupReference   String?
  adminNotes      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Facility {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  imageUrl    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Partner {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
